# Reference copy of the base unit as installed on the server.
# The migration ordering is layered on via the .d/10-wait-migration.conf drop-in
# (systemctl edit HomeMonitoringSensorAgent) so this base file stays untouched.
[Unit]
Description=My Application Service
After=network.target

[Service]
Type=simple
User=bert
WorkingDirectory=/home/bert/AgentLinux
ExecStart=/home/bert/AgentLinux/HomeMonitoring.SensorAgent
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target

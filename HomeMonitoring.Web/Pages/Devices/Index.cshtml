@page
@using HomeMonitoring.Shared.Models
@model IndexModel
@{
    ViewData["Title"] = "Devices";
}

<h1>Devices</h1>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<p>
    <a asp-page="Create" class="btn btn-primary">Add New Device</a>
</p>

@if (Model.Devices.Any())
{
    <table class="table">
        <thead>
        <tr>
            <th>Name</th>
            <th>Type</th>
            <th>IP Address</th>
            <th>Status</th>
            <th>Last Seen</th>
            <th></th>
        </tr>
        </thead>
        <tbody>
        @foreach (var device in Model.Devices)
        {
            <tr>
                <td>@device.Name</td>
                <td>
                    @switch (device.ProductType)
                    {
                        case HomeWizardProductType.HWE_P1:
                            <span class="badge bg-primary">P1 Meter</span>
                            break;
                        case HomeWizardProductType.HWE_SKT:
                            <span class="badge bg-info">Energy Socket</span>
                            break;
                        default:
                            <span class="badge bg-secondary">@device.ProductTypeRaw</span>
                            break;
                    }
                </td>
                <td>@device.IpAddress</td>
                <td>
                    @if (device.IsEnabled)
                    {
                        <span class="badge bg-success">Active</span>
                    }
                    else
                    {
                        <span class="badge bg-warning">Disabled</span>
                    }
                </td>
                <td>
                    @{
                        var timeSinceLastSeen = DateTime.UtcNow - device.LastSeenAt;
                        var isRecent = timeSinceLastSeen.TotalMinutes < 5;
                    }
                    <span class="@(isRecent ? "text-success" : "text-muted")">
                        @device.LastSeenAt.ToLocalTime().ToString("g")
                    </span>
                </td>
                <td>
                    <a asp-page="./Edit" asp-route-id="@device.Id" class="btn btn-sm btn-primary">Edit</a>
                    <a asp-page="./Details" asp-route-id="@device.Id" class="btn btn-sm btn-info">Details</a>
                    <button type="button" class="btn btn-sm btn-danger"
                            data-bs-toggle="modal" data-bs-target="#deleteDeviceModal"
                            data-device-id="@device.Id" data-device-name="@device.Name">
                        Delete
                    </button>
                </td>
            </tr>
        }
        </tbody>
    </table>
}
else
{
    <div class="alert alert-info">
        <h4 class="alert-heading">No devices found</h4>
        <p>You haven't added any HomeWizard devices yet. Click the "Add New Device" button to get started.</p>
        <hr>
        <p class="mb-0">Currently supported devices: HWE-P1 (P1 Meter) and HWE-SKT (Energy Socket)</p>
    </div>
}

<!-- Shared delete-confirmation modal; populated per-device via data-* attributes on the trigger button. -->
<div class="modal fade" id="deleteDeviceModal" tabindex="-1" aria-labelledby="deleteDeviceModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="deleteDeviceModalLabel">Delete device</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>You are about to delete <strong id="deleteDeviceName"></strong>.</p>
                <div class="alert alert-danger mb-0" role="alert">
                    All collected data (energy readings) for this device will be
                    <strong>permanently deleted and cannot be recovered.</strong>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <form method="post" asp-page-handler="Delete">
                    <input type="hidden" name="id" id="deleteDeviceId" />
                    <button type="submit" class="btn btn-danger">Delete permanently</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('deleteDeviceModal').addEventListener('show.bs.modal', function (event) {
            const button = event.relatedTarget;
            document.getElementById('deleteDeviceId').value = button.getAttribute('data-device-id');
            document.getElementById('deleteDeviceName').textContent = button.getAttribute('data-device-name');
        });
    </script>
}
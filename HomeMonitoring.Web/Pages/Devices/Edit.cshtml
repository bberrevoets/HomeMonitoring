@page "{id:int}"
@using HomeMonitoring.Shared.Models
@model EditModel
@{
    ViewData["Title"] = "Edit Device";
}

<h1>Edit Device</h1>

<hr/>
<div class="row">
    <div class="col-md-6">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label class="form-label">Serial Number</label>
                <input class="form-control" value="@Model.SerialNumber" disabled/>
            </div>

            <div class="mb-3">
                <label class="form-label">IP Address</label>
                <input class="form-control" value="@Model.IpAddress" disabled/>
            </div>

            <div class="mb-3">
                <label class="form-label">Type</label>
                <div>
                    @switch (Model.ProductType)
                    {
                        case HomeWizardProductType.HWE_P1:
                            <span class="badge bg-primary">P1 Meter</span>
                            break;
                        case HomeWizardProductType.HWE_SKT:
                            <span class="badge bg-info">Energy Socket</span>
                            break;
                        default:
                            <span class="badge bg-secondary">@Model.ProductType</span>
                            break;
                    }
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="Input.Name" class="form-label"></label>
                <input asp-for="Input.Name" class="form-control" placeholder="Living Room"/>
                <span asp-validation-for="Input.Name" class="text-danger"></span>
                <small class="form-text text-muted">A friendly name to identify this device</small>
            </div>

            <div class="mb-3">
                <input type="submit" value="Save" class="btn btn-primary"/>
                <a asp-page="Index" class="btn btn-secondary">Back to List</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
